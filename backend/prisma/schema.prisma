generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  SCHEDULED
  COMPLETED
  NO_SHOW
  EXPIRED
  BARBER_CANCELLED
  CANCELLED
}

model Customer {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  firstName    String
  lastName     String
  phone        String        @unique
  password     String
  refreshToken String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  appointments Appointment[]
}

model Barber {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  firstName    String
  lastName     String
  phone        String        @unique
  password     String
  active       Boolean       @default(true)
  image        String?
  refreshToken String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  breaks        BreakPeriod[]
  appointments Appointment[]
  workingHours  WorkingHour[]
}

model Admin {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  firstName    String
  lastName     String
  phone        String    @unique
  password     String
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Appointment {
  id            Int        @id @default(autoincrement())
  customerId    Int
  barberId      Int
  
  appointmentStartAt DateTime
  appointmentEndAt   DateTime

  status        Status     @default(SCHEDULED)
  notes         String?
  cancelReason  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  cancelledAt   DateTime? 

  customer      Customer   @relation(fields: [customerId], references: [id])
  barber        Barber     @relation(fields: [barberId], references: [id])

  appointmentServices AppointmentService[]

  @@index([barberId, appointmentStartAt])
  @@index([appointmentStartAt, appointmentEndAt])
}


model Service {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  price        Decimal       @db.Decimal(10, 2)
  duration     Int
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  appointmentServices AppointmentService[]
}

model AppointmentService {
  id            Int          @id @default(autoincrement())
  appointmentId Int
  serviceId     Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  service       Service     @relation(fields: [serviceId], references: [id])
}

enum Range {
  MIN15
  MIN30
}

model WorkingHour {
  id         Int    @id @default(autoincrement())
  barberId   Int
  dayOfWeek  Int   
  startMin   Int    
  endMin     Int    
  slotSize   Range  @default(MIN15)

  barber   Barber @relation(fields: [barberId], references: [id])
  breaks   BreakPeriod[]

  @@index([barberId, dayOfWeek])
  @@unique([barberId, dayOfWeek])
}

model BreakPeriod {
  id         Int  @id @default(autoincrement())
  barberId   Int
  workingHourId Int
  startMin   Int
  endMin     Int

  createdAt  DateTime @default(now())
  updatedAt  DateTime? @updatedAt

  barber Barber @relation(fields: [barberId], references: [id])
  workingHour WorkingHour @relation(fields: [workingHourId], references: [id])
  @@unique([workingHourId, startMin, endMin])
}

model HolidayDate {
  id          Int    @id @default(autoincrement())
  date        DateTime @unique
  reason      String
  createdAt   DateTime @default(now())
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String?
  phone     String?
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([phone])
  @@index([expiresAt])
}

model PushToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String 
  token     String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId, role])
  @@unique([userId, role])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime @default(now())
}