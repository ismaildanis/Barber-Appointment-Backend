generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  SCHEDULED
  COMPLETED
  NO_SHOW
  EXPIRED
  BARBER_CANCELLED
  CANCELLED
}

model Customer {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  firstName    String
  lastName     String
  phone        String?        @unique
  password     String
  refreshToken String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  appointments Appointment[]
  rewards      Reward[]
  gameSessions GameSession[]
}

model Barber {
  id           Int           @id @default(autoincrement())
  shopId       Int
  email        String        @unique
  firstName    String
  lastName     String
  phone        String?        @unique
  password     String
  active       Boolean       @default(true)
  image        String?
  refreshToken String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  breaks        BreakPeriod[]
  appointments  Appointment[]
  workingHours  WorkingHour[]

  shop          Shop @relation(fields: [shopId], references: [id])
}

model Admin {
  id           Int       @id @default(autoincrement())
  shopId       Int
  email        String    @unique
  firstName    String
  lastName     String
  phone        String?    @unique
  password     String
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  shop         Shop @relation(fields: [shopId], references: [id])
}

model Shop {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  city      String
  district  String
  neighborhood String
  address   String    
  phone     String?   @unique
  email     String    @unique
  image     String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  admins    Admin[]
  barbers   Barber[]
  appointments Appointment[]
  holidayDates HolidayDate[]
  services  Service[]
  campaigns Campaign[]
  rewards Reward[]
  gameSessions GameSession[]
}

model Appointment {
  id            Int        @id @default(autoincrement())
  customerId    Int?
  barberId      Int
  shopId        Int
  appointmentStartAt DateTime
  appointmentEndAt   DateTime

  status        Status     @default(SCHEDULED)
  notes         String?
  cancelReason  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  cancelledAt   DateTime? 

  shop          Shop       @relation(fields: [shopId], references: [id])
  customer      Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  barber        Barber     @relation(fields: [barberId], references: [id])

  appointmentServices AppointmentService[]
  rewards      Reward[]

  @@index([barberId, appointmentStartAt])
  @@index([appointmentStartAt, appointmentEndAt])
}

model Service {
  id           Int           @id @default(autoincrement())
  shopId       Int
  name         String
  description  String?
  price        Decimal       @db.Decimal(10, 2)
  duration     Int
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  shop        Shop @relation(fields: [shopId], references: [id])

  appointmentServices AppointmentService[]
  campaignServices CampaignService[]

}

model AppointmentService {
  id            Int          @id @default(autoincrement())
  appointmentId Int
  serviceId     Int
  name          String
  price         Decimal      @db.Decimal(10, 2)
  duration      Int

  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  service       Service     @relation(fields: [serviceId], references: [id])
}

enum Range {
  MIN15
  MIN30
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Campaign {
  id        Int    @id @default(autoincrement())
  shopId    Int
  name      String
  description String?
  discountType  DiscountType
  discountValue Decimal? @db.Decimal(10, 2)
  startAt DateTime
  endAt   DateTime?
  wheelEnabled Boolean @default(true)
  wheelWeight Int @default(10)
  active  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
  rewards Reward[]
  campaignServices CampaignService[]

  @@index([shopId, active, wheelEnabled, startAt, endAt])
}

model CampaignService {
  id         Int       @id @default(autoincrement())
  campaignId  Int
  serviceId   Int

  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  service     Service   @relation(fields: [serviceId], references: [id])

  @@unique([campaignId, serviceId])
}

enum RewardStatus {
  AVAILABLE
  USED
  EXPIRED
}

model Reward {
  id Int @id @default(autoincrement())
  shopId Int
  customerId Int
  campaignId Int
  appointmentId Int?
  status  RewardStatus @default(AVAILABLE)
  usedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  campaign Campaign @relation(fields: [campaignId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([shopId, customerId, status])
  @@unique([appointmentId])
}

enum GameType {
  SPIN_WHEEL
}

model GameSession {
  id        Int    @id @default(autoincrement())
  shopId    Int
  customerId Int
  gameType  GameType 
  playedAt  DateTime

  shop Shop @relation(fields: [shopId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([shopId, customerId, gameType])
  @@index([shopId, customerId, playedAt])
}

model WorkingHour {
  id         Int    @id @default(autoincrement())
  barberId   Int
  dayOfWeek  Int   
  startMin   Int    
  endMin     Int    
  slotSize   Range  @default(MIN15)

  barber   Barber @relation(fields: [barberId], references: [id])
  breaks   BreakPeriod[]

  @@index([barberId, dayOfWeek])
  @@unique([barberId, dayOfWeek])
}

model BreakPeriod {
  id         Int  @id @default(autoincrement())
  barberId   Int
  workingHourId Int
  startMin   Int
  endMin     Int

  createdAt  DateTime @default(now())
  updatedAt  DateTime? @updatedAt

  barber Barber @relation(fields: [barberId], references: [id])
  workingHour WorkingHour @relation(fields: [workingHourId], references: [id])
  @@unique([workingHourId, startMin, endMin])
}

model HolidayDate {
  id          Int    @id @default(autoincrement())
  shopId      Int
  date        DateTime 
  reason      String
  createdAt   DateTime @default(now())

  shop        Shop @relation(fields: [shopId], references: [id])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String?
  phone     String?
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model PushToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String 
  token     String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId, role])
  @@unique([userId, role], name: "userId_role")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime @default(now())
}