generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  SCHEDULED
  COMPLETED
  NO_SHOW
  EXPIRED
  BARBER_CANCELLED
  CANCELLED
}

model Customer {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  firstName    String
  lastName     String
  phone        String
  password     String
  refreshToken String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  appointments Appointment[]
}

model Barber {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  firstName    String
  lastName     String
  phone        String
  password     String
  active       Boolean       @default(true)
  image        String?
  refreshToken String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  appointments Appointment[]
  workingHours  WorkingHour[]
}

model Admin {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  firstName    String
  lastName     String
  phone        String
  password     String
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Appointment {
  id            Int        @id @default(autoincrement())
  customerId    Int
  barberId      Int
  serviceId     Int
  
  appointmentStartAt DateTime
  appointmentEndAt   DateTime

  status        Status     @default(SCHEDULED)
  notes         String?
  cancelReason  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  cancelledAt   DateTime? 

  customer      Customer   @relation(fields: [customerId], references: [id])
  barber        Barber     @relation(fields: [barberId], references: [id])
  service       Service    @relation(fields: [serviceId], references: [id])

  @@index([barberId, appointmentStartAt])
  @@index([appointmentStartAt, appointmentEndAt])
}


model Service {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  price        Decimal       @db.Decimal(10, 2)
  duration     Int
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  appointments Appointment[]
}

enum Range {
  MIN15
  MIN30
}

model WorkingHour {
  id         Int    @id @default(autoincrement())
  barberId   Int
  dayOfWeek  Int   
  startMin   Int    
  endMin     Int    
  slotSize   Range  @default(MIN15)

  barber   Barber @relation(fields: [barberId], references: [id])
  breaks   BreakPeriod[]

  @@index([barberId, dayOfWeek])
  @@unique([barberId, dayOfWeek, startMin, endMin])
}

model BreakPeriod {
  id         Int  @id @default(autoincrement())
  workingHourId Int
  startMin   Int
  endMin     Int

  workingHour WorkingHour @relation(fields: [workingHourId], references: [id])
}

model HolidayDate {
  id          Int    @id @default(autoincrement())
  date        DateTime @unique
  reason      String
  createdAt   DateTime @default(now())
}